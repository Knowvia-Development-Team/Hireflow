# ─────────────────────────────────────────────────────────────────────────────
#  HireFlow Frontend — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (Express server)
VITE_API_URL=http://localhost:3001

# Enable Hugging Face AI features
VITE_HF_ENABLED=true

# Sentry DSN for error monitoring (leave empty to disable)
VITE_SENTRY_DSN=

# App environment: development | staging | production
VITE_ENV=development

# Semver string shown in the UI footer / Sentry releases
VITE_APP_VERSION=1.0.0

DB_MODE=sqlite
DEV_AUTH_EMAIL=mika.sato@northgrid.io
DEV_AUTH_PASSWORD=Password123!

