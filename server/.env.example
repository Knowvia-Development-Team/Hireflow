# ─────────────────────────────────────────────────────────────────
#  Get your free token at https://huggingface.co/settings/tokens
#  Copy this file to .env and paste your token below
# ─────────────────────────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port the Express server runs on (React dev server proxies to this)
PORT=3001

# ─────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────
DB_MODE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hireflow
DB_USER=postgres
DB_PASSWORD=postgres

# Dev Auth (used when DB_MODE=sqlite or memory)
DEV_AUTH_EMAIL=mika.sato@northgrid.io
DEV_AUTH_PASSWORD=Password123!
DEV_AUTH_NAME=Mika Sato
DEV_AUTH_ROLE=Admin

# ─────────────────────────────────────────────────────────────────
# JWT Authentication (REQUIRED for production)
# Generate secure random strings:
# - JWT_SECRET: openssl rand -base64 32
# - JWT_REFRESH_SECRET: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=your-secure-random-string-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-secure-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────
# Social Media API Credentials (Optional)
# Fill in to enable social media job posting
# ─────────────────────────────────────────────────────────────────

# LinkedIn (https://developers.linkedin.com/)
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_ORGANIZATION_ID=

# Twitter/X (https://developer.twitter.com/)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# Facebook (https://developers.facebook.com/)
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_PAGE_ID=

# Indeed (https://ads.indeed.com/publisher)
# INDEED_PUBLISHER_ID=

# ─────────────────────────────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────────────────────────────
# For local storage (default)
UPLOAD_DIR=./uploads

# For S3 storage (optional)
# S3_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
